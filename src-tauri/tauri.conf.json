{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Macten",
  "version": "0.1.0",
  "identifier": "com.macten.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Macten",
        "width": 800,
        "height": 76,
        "x": 400,
        "y": 200,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "shadow": false,
        "center": false,
        "fullscreen": false,
        "maximizable": false,
        "minimizable": false,
        "closable": true,
        "focus": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "app",
    "icon": ["icons/icon.png"]
  }
}
